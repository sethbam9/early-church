{
  "name": "early-christianity-map",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run data:validate",
    "dev": "vite",
    "data:derive-places": "tsx scripts/derive_places.ts",
    "data:derive-footprints": "tsx scripts/derive_footprints.ts",
    "data:derive-mentions": "tsx scripts/derive_mentions.ts",
    "data:derive": "tsx scripts/derive_places.ts && tsx scripts/derive_footprints.ts && tsx scripts/derive_mentions.ts",
    "data:validate": "npm run data:derive && tsx scripts/validate_data.ts",
    "prebuild": "npm run data:validate",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.3",
    "d3-dsv": "^3.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
