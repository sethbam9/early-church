{
  "name": "early-christianity-map",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build:data",
    "dev": "vite",
    "data:final": "tsx scripts/build_final_data_from_final.ts",
    "data:validate": "tsx scripts/validate_data.ts",
    "data:rebuild": "npm run data:final && npm run data:validate && tsx scripts/tsv_to_json.ts && tsx scripts/build_entities.ts",
    "build:data": "npm run data:rebuild",
    "prebuild": "npm run build:data",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "d3-dsv": "^3.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
