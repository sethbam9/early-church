{
  "name": "early-christianity-map",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky install",
    "data:derive": "tsx scripts/derive_places.ts && tsx scripts/derive_footprints.ts && tsx scripts/derive_mentions.ts",
    "data:validate": "python3 scripts/validate_canonical_data.py --data-dir data --scan-root data/sheets",
    "data:validate-full": "npm run data:derive && python3 scripts/validate_canonical_data.py --data-dir data --scan-root data/sheets"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.3",
    "d3-dsv": "^3.0.1",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
